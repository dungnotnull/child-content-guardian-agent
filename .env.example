# --- API Configuration ---
# If using Claude, provide your API Key
CLAUDE_API_KEY=your_anthropic_key_here

# If using OpenAI, provide your API Key
OPENAI_API_KEY=your_openai_key_here

# --- System Configuration ---
# LLM_PROVIDER: 'ollama' (default), 'claude', or 'openai'
LLM_PROVIDER=ollama
OLLAMA_ENDPOINT=http://localhost:11434/api/generate

# --- Security ---
# Secret key used for Chrome Extension to API communication
API_KEY=secret-parent-key

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./guardian.db
